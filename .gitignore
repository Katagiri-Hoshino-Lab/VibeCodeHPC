# VibeCodeHPC - Multi-CLI Multi-Agent HPC Optimization Framework
# .gitignore - Security files only. CD agent handles file review and anonymization.

# ===========================================
# CRITICAL SECURITY FILES - NEVER COMMIT
# ===========================================

# Remote connection and authentication (README.md tracked, contents gitignored)
_remote_info/*
!_remote_info/README.md
*.pem
*.key
*_rsa*
*_dsa*
*_ecdsa*
*_ed25519*
.ssh/
ssh_config
known_hosts*

# User and project IDs (before anonymization)
user_id.txt
project_id.txt
*.env
.env*

# HPC authentication and credentials
.queuerc
.slurmrc
*_credentials*
*_passwd*
*_token*

# ===========================================
# STANDARD DEVELOPMENT FILES
# ===========================================

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Cache directories
.cache/
*.pkl.gz

# ===========================================
# CLI RUNTIME (per-agent, regenerated by adapter)
# ===========================================
.claude/settings.local.json
.claude/hooks/

# ===========================================
# LOCAL TEST RUNS
# ===========================================
test_runs/

# ===========================================
# TELEMETRY
# ===========================================
claude_code_prompts*.jsonl
claude_code_events*.jsonl
telemetry/sub_agent_logs/
**/grafana-data/
**/prometheus-data/
**/loki-data/

# ===========================================
# NOTES
# ===========================================
# The following are INTENTIONALLY TRACKED (CD agent reviews before commit):
# - Agent-shared/agent_and_pane_id_table.jsonl (agent registry)
# - Agent-shared/project_start_time.txt (project timeline)
# - Agent-shared/max_agent_number.txt (agent count)
# - communication/logs/ (communication records)
# - sota_*.txt (performance tracking)
# - ChangeLog.md (optimization history)
.pytest_cache/
